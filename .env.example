# EPA Knowledge Graph — Environment Template
# Copy to .env and fill in your values

# Embedding Provider
# Options: fastembed (local, default), openai
EMBEDDING_PROVIDER=fastembed

# OpenAI (only needed if EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Local LLM for metadata extraction (Ollama)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2:3b

# Database
# PostgreSQL (for users, tenants, audit logs)
DATABASE_URL=postgresql://user:password@localhost:5432/epa_kg

# ChromaDB (vector store) — embedded by default, override if using remote
# CHROMA_HOST=localhost
# CHROMA_PORT=8000

# EPA Method PDFs directory (for ingestion)
EPA_PDF_DIR=./epa-methods

# Logging
RUST_LOG=info