# EPA Knowledge Graph — Environment Template
# Copy to .env and fill in your values:  cp .env.example .env
#
# NOTE ON SECRETS: API keys are NOT stored here. Set them as real environment
# variables in your shell profile / CI secrets (see "Secrets" section at bottom).
# The ingestion service reads secrets from the process environment, never from
# a committed file, and never logs them.

# ── App / Service ────────────────────────────────────────────────────────────
EPA_KG__HOST=127.0.0.1
EPA_KG__PORT=8001
EPA_KG__LOG_LEVEL=info
EPA_KG__RELOAD=false                 # Disable auto-reload (prevents worker crash on file change)
EPA_KG__DATA_DIR=./data

# ── ChromaDB (vector store) ───────────────────────────────────────────────────
EPA_KG__CHROMA_HOST=127.0.0.1
EPA_KG__CHROMA_PORT=8000
EPA_KG__CHROMA_COLLECTION=epa_methods
EPA_KG__CHROMA_PERSIST_DIR=./data/chroma

# ChromaDB Cloud (optional — uncomment and set secret below)
# EPA_KG__CHROMA_USE_CLOUD=true
# EPA_KG__CHROMA_TENANT=your_tenant
# EPA_KG__CHROMA_DATABASE=your_database

# ── Ingestion ─────────────────────────────────────────────────────────────────
EPA_KG__PDF_DIR=C:/Users/AlexJ/Documents/Coding/Repos/my-repos/EPA-Project/EPA_Methods_PDF
EPA_KG__CHUNK_SIZE=512
EPA_KG__CHUNK_OVERLAP=64
EPA_KG__TOC_AWARE=true
EPA_KG__EXTRACT_TABLES=true
EPA_KG__MAX_FILE_SIZE_MB=100
# NOTE: max_files is a per-request parameter on POST /ingest (body), not an env var.
#       Use it to limit how many PDFs are ingested in one call (e.g. 50 for a fast test).

# ── Embeddings — choose ONE provider ──────────────────────────────────────────
# Option 1: FastEmbed (local, default — no API key needed)
EPA_KG__EMBEDDING_PROVIDER=fastembed
EPA_KG__FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
EPA_KG__FASTEMBED_BATCH_SIZE=32

# Option 2: OpenRouter (remote — requires OPENROUTER_API_KEY secret)
# EPA_KG__EMBEDDING_PROVIDER=openrouter
# EPA_KG__OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# EPA_KG__OPENROUTER_EMBEDDING_DIMENSIONS=1536
# EPA_KG__OPENROUTER_EMBEDDING_BATCH_SIZE=32

# Option 3: Ollama (local)
# EPA_KG__EMBEDDING_PROVIDER=ollama
# EPA_KG__OLLAMA_EMBEDDING_HOST=http://localhost:11434
# EPA_KG__OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# EPA_KG__OLLAMA_EMBEDDING_BATCH_SIZE=32

# ── LLM (metadata extraction) — choose ONE provider ──────────────────────────
# Option 1: None (regex fallback only — no API key needed)
EPA_KG__LLM_PROVIDER=none

# Option 2: OpenRouter (remote — requires OPENROUTER_API_KEY secret)
# EPA_KG__LLM_PROVIDER=openrouter
# EPA_KG__OPENROUTER_LLM_MODEL=anthropic/claude-3.5-sonnet
# EPA_KG__OPENROUTER_LLM_TEMPERATURE=0.1
# EPA_KG__OPENROUTER_LLM_MAX_TOKENS=2048

# Option 3: Ollama (local)
# EPA_KG__LLM_PROVIDER=ollama
# EPA_KG__OLLAMA_LLM_HOST=http://localhost:11434
# EPA_KG__OLLAMA_LLM_MODEL=llama3.2:3b
# EPA_KG__OLLAMA_LLM_TEMPERATURE=0.1
# EPA_KG__OLLAMA_LLM_MAX_TOKENS=2048

# ── Reranker (Phase 2+) — optional ────────────────────────────────────────────
# EPA_KG__RERANKER_PROVIDER=none
# EPA_KG__RERANKER_OPENROUTER_MODEL=nvidia/llama-nemotron-rerank-vl-1b-v2:free

# ── Secrets (DO NOT put keys in this file) ────────────────────────────────────
# Set these as real environment variables (export in ~/.bashrc, GitHub Actions
# secrets, Docker secrets, etc.). The service reads them from the process env.
#
#   Single shared key for all OpenRouter providers (embeddings + LLM + reranker):
#     export OPENROUTER_API_KEY=sk-or-v1-...
#
#   ChromaDB Cloud API key (only if EPA_KG__CHROMA_USE_CLOUD=true):
#     export CHROMADB_API_KEY=your_chromadb_cloud_api_key
#
# Provider-specific overrides (optional — fall back to OPENROUTER_API_KEY if unset):
#     export EPA_KG__OPENROUTER_EMBEDDING_API_KEY=sk-or-v1-...
#     export EPA_KG__OPENROUTER_LLM_API_KEY=sk-or-v1-...
#     export EPA_KG__CHROMA_API_KEY=your_chromadb_cloud_api_key
