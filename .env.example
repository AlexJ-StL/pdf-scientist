# EPA Knowledge Graph — Environment Template
# Copy to .env and fill in your values

# App
EPA_KG__APP__HOST=127.0.0.1
EPA_KG__APP__PORT=8080
EPA_KG__APP__LOG_LEVEL=info
EPA_KG__APP__DATA_DIR=./data

# Database (PostgreSQL)
EPA_KG__DATABASE__URL=postgresql://postgres:postgres@localhost:5432/epa_kg
EPA_KG__DATABASE__MAX_CONNECTIONS=10
EPA_KG__DATABASE__MIN_CONNECTIONS=1

# ChromaDB
EPA_KG__CHROMA__HOST=127.0.0.1
EPA_KG__CHROMA__PORT=8000
EPA_KG__CHROMA__COLLECTION_NAME=epa_methods
EPA_KG__CHROMA__PERSIST_DIR=./data/chroma

# ChromaDB Cloud (optional)
# EPA_KG__CHROMA__USE_CLOUD=true
# EPA_KG__CHROMA__API_KEY=your_chromadb_cloud_api_key
# EPA_KG__CHROMA__TENANT=your_tenant
# EPA_KG__CHROMA__DATABASE=your_database

# Ingestion
EPA_KG__INGESTION__PDF_DIR=C:/Users/AlexJ/Documents/Coding/Repos/my-repos/EPA-Project/EPA_Methods_PDF
EPA_KG__INGESTION__CHUNK_SIZE=512
EPA_KG__INGESTION__CHUNK_OVERLAP=64
EPA_KG__INGESTION__TOC_AWARE=true
EPA_KG__INGESTION__EXTRACT_TABLES=true
EPA_KG__INGESTION__MAX_FILE_SIZE_MB=100

# Embeddings - Choose ONE provider:
# Option 1: OpenRouter (remote)
# EPA_KG__EMBEDDING__PROVIDER=openrouter
# EPA_KG__EMBEDDING__OPENROUTER__API_KEY=sk-or-v1-...
# EPA_KG__EMBEDDING__OPENROUTER__MODEL=openai/text-embedding-3-small
# EPA_KG__EMBEDDING__OPENROUTER__DIMENSIONS=1536
# EPA_KG__EMBEDDING__OPENROUTER__BATCH_SIZE=32

# Option 2: Ollama (local)
# EPA_KG__EMBEDDING__PROVIDER=ollama
# EPA_KG__EMBEDDING__OLLAMA__HOST=http://localhost:11434
# EPA_KG__EMBEDDING__OLLAMA__MODEL=nomic-embed-text
# EPA_KG__EMBEDDING__OLLAMA__BATCH_SIZE=32

# Option 3: FastEmbed (local, default - no API key needed)
EPA_KG__EMBEDDING__PROVIDER=fastembed
EPA_KG__EMBEDDING__FASTEMBED__MODEL=BAAI/bge-small-en-v1.5
EPA_KG__EMBEDDING__FASTEMBED__BATCH_SIZE=32

# LLM - Choose ONE provider:
# Option 1: OpenRouter (remote)
# EPA_KG__LLM__PROVIDER=openrouter
# EPA_KG__LLM__OPENROUTER__API_KEY=sk-or-v1-...
# EPA_KG__LLM__OPENROUTER__MODEL=anthropic/claude-3.5-sonnet
# EPA_KG__LLM__OPENROUTER__TEMPERATURE=0.1
# EPA_KG__LLM__OPENROUTER__MAX_TOKENS=2048

# Option 2: Ollama (local)
# EPA_KG__LLM__PROVIDER=ollama
# EPA_KG__LLM__OLLAMA__HOST=http://localhost:11434
# EPA_KG__LLM__OLLAMA__MODEL=llama3.2:3b
# EPA_KG__LLM__OLLAMA__TEMPERATURE=0.1
# EPA_KG__LLM__OLLAMA__MAX_TOKENS=2048

# Option 3: None (no LLM)
EPA_KG__LLM__PROVIDER=none

# OpenRouter API Key (if using OpenRouter for any provider)
# OPENROUTER_API_KEY=sk-or-v1-...

# ChromaDB Cloud API Key (if using ChromaDB Cloud)
# CHROMADB_API_KEY=your_chromadb_cloud_api_key